{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentic-sdlc.dev/schemas/v1/plan.schema.json",
  "title": "Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "task_id",
    "schema_version",
    "steps",
    "success_criteria"
  ],
  "properties": {
    "schema_version": {
      "const": "v1"
    },
    "id": {
      "type": "string"
    },
    "task_id": {
      "type": "string"
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "description", "status"],
        "properties": {
          "id": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "depends_on": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "status": {
            "type": "string",
            "enum": ["pending", "in_progress", "done", "blocked"]
          }
        }
      }
    },
    "success_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  }
}
