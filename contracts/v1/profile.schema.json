{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentic-sdlc.dev/schemas/v1/repo-profile.schema.json",
  "title": "RepoProfile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "repository",
    "working_roots",
    "commands",
    "protected_paths"
  ],
  "properties": {
    "schema_version": {
      "const": "v1"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["owner", "name"],
      "properties": {
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "default_branch": {
          "type": "string"
        }
      }
    },
    "ecosystems": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "working_roots": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "important_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "protected_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "commands": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "test": {
          "type": "string"
        },
        "lint": {
          "type": "string"
        },
        "build": {
          "type": "string"
        }
      }
    },
    "ci": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "provider": {
          "type": "string"
        },
        "required_checks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "pull_request": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "provider": {
          "type": "string"
        },
        "required_approvals": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
