{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentic-sdlc.dev/schemas/v1/evaluation.schema.json",
  "title": "Evaluation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "schema_version",
    "target_artifact_ids",
    "result",
    "score",
    "feedback",
    "retryable",
    "risk_level",
    "evidence",
    "evaluated_at"
  ],
  "properties": {
    "schema_version": {
      "const": "v1"
    },
    "id": {
      "type": "string"
    },
    "target_artifact_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "result": {
      "type": "string",
      "enum": ["pass", "fail"]
    },
    "score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "feedback": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "retryable": {
      "type": "boolean"
    },
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evaluated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
