{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentic-sdlc.dev/schemas/v1/task.schema.json",
  "title": "Task",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "type",
    "description",
    "acceptance_criteria",
    "priority",
    "constraints",
    "schema_version"
  ],
  "properties": {
    "schema_version": {
      "const": "v1"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "enum": ["feature", "bugfix", "refactor", "ktlo", "research", "docs"]
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "priority": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "description": "Traceability link to the external system where this task originated.",
      "required": ["system", "external_id"],
      "properties": {
        "system": {
          "type": "string",
          "description": "The intake source system (e.g., jira, github_issues, slack, api, manual)."
        },
        "external_id": {
          "type": "string",
          "description": "The identifier in the source system (e.g., JIRA ticket key, GH issue number)."
        },
        "url": {
          "type": "string",
          "format": "uri",
          "description": "Direct URL to the original work item."
        }
      }
    },
    "resolved_autonomy_level": {
      "type": "string",
      "enum": ["assistive", "semi_autonomous", "bounded_autonomous", "fully_autonomous"],
      "description": "The effective autonomy level for this task, resolved during triage from the repo policy and task type overrides. Set by the orchestration engine, not the intake adapter."
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
