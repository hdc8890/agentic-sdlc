{
  "schema_version": "v1",
  "id": "repo-profile-meal-planner",
  "repository": {
    "owner": "davidchen",
    "name": "meal-planner",
    "default_branch": "main"
  },
  "ecosystems": [
    "rust",
    "sqlite",
    "node",
    "typescript",
    "react"
  ],
  "working_roots": [
    "src",
    "tests",
    "frontend",
    "templates",
    "plans"
  ],
  "important_paths": [
    "Cargo.toml",
    "README.md",
    "src",
    "tests",
    "frontend/package.json",
    "templates"
  ],
  "protected_paths": [
    ".github",
    ".claude",
    ".copilot",
    ".squad",
    "meal_planner.db",
    "target"
  ],
  "commands": {
    "test": "cargo test",
    "lint": "cargo fmt --check && cargo clippy && cd frontend && npm run lint",
    "build": "cargo build --release && cd frontend && npm run build"
  },
  "ci": {
    "provider": "github-actions"
  },
  "pull_request": {
    "provider": "github"
  },
  "metadata": {
    "notes": "Derived from the observed meal-planner repository structure. Commands reflect the current Rust backend and frontend package setup."
  }
}
